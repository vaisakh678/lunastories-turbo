# Copy this file to app/keystore.properties and fill in the real values.
# keystore.properties is gitignored — never commit real credentials.
#
# Generate the keystore (one-time) with:
#   keytool -genkey -v -keystore luna-upload.jks \
#     -alias luna-upload -keyalg RSA -keysize 2048 -validity 36500
# Save the .jks somewhere outside the repo (e.g. ~/keystores/luna-upload.jks).

storeFile=/absolute/path/to/luna-upload.jks
storePassword=your-keystore-password
keyAlias=luna-upload
keyPassword=your-key-password

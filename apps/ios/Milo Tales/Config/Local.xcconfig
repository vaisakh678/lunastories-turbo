// Local development environment — points at a dev server running on the host machine.
// xcconfig URL escape: `//` is a comment. `$()` is an empty variable interpolation
// that breaks the parser without changing the value. So `https:/$()/host` reads as
// `https://host` after substitution.

INFOPLIST_KEY_API_BASE_URL = http:/$()/localhost:3001
INFOPLIST_KEY_CFBundleDisplayName = Milo Tales (Local)

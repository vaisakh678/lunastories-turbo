    "@clerk/backend": "^2.0.0",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@repo/db": "workspace:*",
    "@repo/dto": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/zod": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.8",
    "openai": "^6.34.0",
    "pino": "^9.5.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.21.4",
